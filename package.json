{
  "name": "shopify-node-app",
  "version": "1.0.6",
  "eslintConfig": {
    "env": {
      "browser": true,
      "node": true
    }
  },
  "description": "Shopify's node app for CLI tool",
  "scripts": {
    "test": "jest",
    "serve": "concurrently --raw \"ngrok http 8081 -region eu -subdomain=ingrid\" \"shopify app serve --host=https://ingrid.eu.ngrok.io\"",
    "dev": "cross-env NODE_ENV=development nodemon ./server/index.js --watch ./server/index.js",
    "build": "next build",
    "start": "node server/index.js",
    "railway:start": "node server/index.js",
    "deploy": "shopify app deploy",
    "preversion": "",
    "version": "git add -A",
    "postversion": "git push --tags",
    "prettier": "prettier --write \"**/*.{js,jsx,json,ts,tsx,md,mdx,css,html,yml,yaml,scss,sass}\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Shopify/shopify-node-app.git"
  },
  "author": "Shopify Inc.",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/shopify/shopify-node-app/issues"
  },
  "dependencies": {
    "@babel/core": "7.20.5",
    "@babel/polyfill": "^7.12.1",
    "@babel/preset-env": "^7.20.2",
    "@babel/register": "^7.18.9",
    "@google-cloud/pubsub": "^3.2.1",
    "@koa/router": "^12.0.0",
    "@shopify/app-bridge": "^3.4.3",
    "@shopify/app-bridge-react": "^3.4.3",
    "@shopify/app-bridge-utils": "^3.4.3",
    "@shopify/koa-shopify-auth": "^5.0.3",
    "@shopify/koa-shopify-graphql-proxy": "^7.0.2",
    "@shopify/koa-shopify-webhooks": "^5.0.4",
    "@shopify/polaris": "^10.13.0",
    "@shopify/polaris-icons": "^6.6.0",
    "@shopify/react-i18n": "^7.4.0",
    "@shopify/shopify-api": "^5.2.0",
    "apollo-boost": "^0.4.9",
    "axios": "^0.27.2",
    "cross-fetch": "^3.1.5",
    "firebase": "^9.14.0",
    "firebase-admin": "^11.3.0",
    "graphql": "^16.6.0",
    "isomorphic-fetch": "^3.0.0",
    "isomorphic-unfetch": "^3.1.0",
    "jsonwebtoken": "^8.5.1",
    "koa": "^2.13.4",
    "koa-bodyparser": "^4.3.0",
    "koa-mount": "^4.0.0",
    "koa-session": "^6.2.0",
    "koa-static": "^5.0.0",
    "lodash": "^4.17.21",
    "lscache": "^1.3.2",
    "next": "^13.0.6",
    "next-env": "^1.1.1",
    "next-i18next": "^13.0.0",
    "node-cron": "^3.0.3",
    "prop-types": "^15.8.1",
    "react": "^18.2.0",
    "react-apollo": "^3.1.5",
    "react-dom": "^18.2.0",
    "sass": "^1.56.1",
    "simple-koa-shopify-auth": "^2.1.10"
  },
  "devDependencies": {
    "@babel/eslint-parser": "^7.19.1",
    "@babel/plugin-syntax-jsx": "^7.18.6",
    "@babel/preset-react": "^7.18.6",
    "@babel/preset-stage-3": "^7.8.3",
    "@next/eslint-plugin-next": "^13.0.6",
    "babel-jest": "29.3.1",
    "babel-register": "^6.26.0",
    "concurrently": "^7.6.0",
    "cross-env": "^7.0.3",
    "enzyme": "3.11.0",
    "enzyme-adapter-react-16": "1.15.7",
    "eslint-config-next": "^13.0.6",
    "eslint-config-prettier": "^8.5.0",
    "eslint-plugin-chai-expect": "^3.0.0",
    "eslint-plugin-import": "^2.26.0",
    "eslint-plugin-prettier": "^4.2.1",
    "eslint-plugin-promise": "^6.1.1",
    "eslint-plugin-shopify": "^35.1.0",
    "husky": "^8.0.2",
    "jest": "^29.3.1",
    "lint-staged": "^13.1.0",
    "nodemon": "^2.0.20",
    "prettier": "^2.8.0",
    "react-addons-test-utils": "15.6.2",
    "react-test-renderer": "18.2.0"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.{js,css,json,md}": [
      "prettier --write",
      "git add"
    ]
  }
}
