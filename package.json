{
  "name": "shopify-node-app",
  "version": "1.0.6",
  "eslintConfig": {
    "env": {
      "browser": true,
      "node": true
    }
  },
  "description": "Shopify's node app for CLI tool",
  "scripts": {
    "test": "jest",
    "serve": "concurrently -r \"ngrok http 8081 -region eu -subdomain=ingrid\" \"shopify app serve --host=https://ingrid.eu.ngrok.io\"",
    "dev": "cross-env NODE_ENV=development nodemon ./server/index.js --watch ./server/index.js",
    "build": "next build",
    "start": "cross-env NODE_ENV=production node ./server/index.js",
    "preversion": "",
    "version": "git add -A",
    "postversion": "git push --tags",
    "prettier": "prettier --write \"**/*.{js,jsx,json,ts,tsx,md,mdx,css,html,yml,yaml,scss,sass}\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Shopify/shopify-node-app.git"
  },
  "author": "Shopify Inc.",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/shopify/shopify-node-app/issues"
  },
  "dependencies": {
    "@babel/core": "7.17.5",
    "@babel/polyfill": "^7.12.1",
    "@babel/preset-env": "^7.16.11",
    "@babel/register": "^7.17.0",
    "@google-cloud/pubsub": "^2.19.0",
    "@koa/router": "^10.1.1",
    "@reduxjs/toolkit": "^1.8.0",
    "@shopify/app-bridge": "^2.0.17",
    "@shopify/app-bridge-react": "^2.0.17",
    "@shopify/app-bridge-utils": "^2.0.17",
    "@shopify/koa-shopify-auth": "^5.0.3",
    "@shopify/koa-shopify-graphql-proxy": "^6.0.7",
    "@shopify/koa-shopify-webhooks": "^4.4.4",
    "@shopify/polaris": "^9.2.0",
    "@shopify/polaris-icons": "^4.18.1",
    "@shopify/react-i18n": "^6.3.12",
    "@shopify/shopify-api": "^2.1.0",
    "apollo-boost": "^0.4.9",
    "axios": "^0.26.1",
    "cross-fetch": "^3.1.5",
    "firebase": "^9.6.8",
    "firebase-admin": "^10.0.2",
    "graphql": "^16.3.0",
    "isomorphic-fetch": "^3.0.0",
    "isomorphic-unfetch": "^3.1.0",
    "jsonwebtoken": "^8.5.1",
    "koa": "^2.13.4",
    "koa-bodyparser": "^4.3.0",
    "koa-session": "^6.2.0",
    "lodash": "^4.17.21",
    "lscache": "^1.3.0",
    "next": "^12.1.0",
    "next-env": "^1.1.1",
    "next-i18next": "^10.5.0",
    "prop-types": "^15.8.1",
    "react": "^17.0.2",
    "react-apollo": "^3.1.5",
    "react-dom": "^17.0.2",
    "react-redux": "^7.2.6",
    "redux": "^4.1.2",
    "redux-devtools-extension": "^2.13.9",
    "redux-thunk": "^2.4.1",
    "sass": "^1.49.9",
    "simple-koa-shopify-auth": "^1.0.5"
  },
  "devDependencies": {
    "@babel/eslint-parser": "^7.17.0",
    "@babel/plugin-syntax-jsx": "^7.16.7",
    "@babel/preset-react": "^7.16.7",
    "@babel/preset-stage-3": "^7.8.3",
    "@next/eslint-plugin-next": "^12.1.0",
    "babel-jest": "27.5.1",
    "babel-register": "^6.26.0",
    "concurrently": "^7.0.0",
    "cross-env": "^7.0.3",
    "enzyme": "3.11.0",
    "enzyme-adapter-react-16": "1.15.6",
    "eslint-config-next": "^12.1.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-plugin-chai-expect": "^3.0.0",
    "eslint-plugin-import": "^2.25.4",
    "eslint-plugin-prettier": "^4.0.0",
    "eslint-plugin-promise": "^6.0.0",
    "eslint-plugin-shopify": "^35.1.0",
    "husky": "^7.0.4",
    "jest": "27.5.1",
    "lint-staged": "^12.3.5",
    "nodemon": "^2.0.15",
    "prettier": "2.5.1",
    "react-addons-test-utils": "15.6.2",
    "react-test-renderer": "17.0.2"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.{js,css,json,md}": [
      "prettier --write",
      "git add"
    ]
  }
}
