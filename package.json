{
  "name": "shopify-node-app",
  "version": "1.0.6",
  "engines": {
    "node": "11.x"
  },
  "eslintConfig": {
    "env": {
      "browser": true,
      "node": true
    }
  },
  "description": "Shopify's node app for CLI tool",
  "scripts": {
    "test": "jest",
    "serve": "shopify node serve --host=https://ingrid.eu.ngrok.io",
    "dev": "cross-env NODE_ENV=development nodemon ./server/index.js --watch ./server/index.js",
    "build": "next build",
    "start": "cross-env NODE_ENV=production node ./server/index.js",
    "preversion": "",
    "version": "git add -A",
    "postversion": "git push --tags",
    "prettier": "prettier --write \"**/*.{js,jsx,json,ts,tsx,md,mdx,css,html,yml,yaml,scss,sass}\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Shopify/shopify-node-app.git"
  },
  "author": "Shopify Inc.",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/shopify/shopify-node-app/issues"
  },
  "dependencies": {
    "@babel/core": "7.15.0",
    "@babel/polyfill": "^7.12.1",
    "@babel/preset-env": "^7.15.0",
    "@babel/register": "^7.15.3",
    "@google-cloud/pubsub": "^2.16.3",
    "@koa/router": "^10.1.0",
    "@shopify/app-bridge": "^2.0.3",
    "@shopify/app-bridge-react": "^2.0.3",
    "@shopify/app-bridge-utils": "^2.0.3",
    "@shopify/koa-shopify-auth": "^4.1.4",
    "@shopify/koa-shopify-graphql-proxy": "^5.0.2",
    "@shopify/koa-shopify-webhooks": "^3.0.2",
    "@shopify/polaris": "^6.6.0",
    "@shopify/react-i18n": "^6.1.5",
    "@shopify/shopify-api": "^1.4.1",
    "apollo-boost": "^0.4.9",
    "cross-fetch": "^3.1.4",
    "firebase": "^8.9.1",
    "firebase-admin": "^9.11.0",
    "graphql": "^15.5.1",
    "isomorphic-fetch": "^3.0.0",
    "isomorphic-unfetch": "^3.1.0",
    "jsonwebtoken": "^8.5.1",
    "koa": "^2.13.1",
    "koa-bodyparser": "^4.3.0",
    "koa-session": "^6.2.0",
    "lodash": "^4.17.21",
    "lscache": "^1.3.0",
    "next": "^11.1.0",
    "next-env": "^1.1.1",
    "next-i18next": "^8.6.0",
    "node-fetch": "^2.6.1",
    "node-sass": "^6.0.1",
    "prop-types": "^15.7.2",
    "react": "^17.0.2",
    "react-apollo": "^3.1.5",
    "react-dom": "^17.0.2",
    "sass": "^1.37.5"
  },
  "devDependencies": {
    "@babel/preset-stage-3": "^7.8.3",
    "babel-jest": "27.0.6",
    "babel-register": "^6.26.0",
    "cross-env": "^7.0.3",
    "enzyme": "3.11.0",
    "enzyme-adapter-react-16": "1.15.6",
    "eslint": "^7.32.0",
    "eslint-config-next": "^11.1.0",
    "eslint-config-prettier": "^8.3.0",
    "eslint-plugin-chai-expect": "^2.2.0",
    "eslint-plugin-import": "^2.24.0",
    "eslint-plugin-prettier": "^3.4.0",
    "eslint-plugin-promise": "^5.1.0",
    "eslint-plugin-shopify": "^7.0.0",
    "husky": "^7.0.1",
    "jest": "27.0.6",
    "lint-staged": "^11.1.2",
    "nodemon": "^2.0.12",
    "prettier": "2.3.2",
    "react-addons-test-utils": "15.6.2",
    "react-test-renderer": "17.0.2"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.{js,css,json,md}": [
      "prettier --write",
      "git add"
    ]
  }
}
