{% comment %}
  WordPress Post Feed Block
  This block displays WordPress blog posts on Shopify store pages
{% endcomment %}

<div class="wordpress-feed-block" data-shop="{{ shop.permanent_domain }}" data-app-id="{{ app.id }}">
  <div class="wp-feed-container">
    {% if block.settings.show_title %}
      <h2 class="wp-feed-title">{{ block.settings.title | default: "Latest Posts" }}</h2>
    {% endif %}

    <div class="wp-feed-posts" id="wp-feed-posts-{{ block.id }}">
      <p class="wp-feed-loading">Loading posts&hellip;</p>
    </div>
  </div>
</div>

<script>
  (function() {
    var blockId   = '{{ block.id }}';
    var shopDomain = '{{ shop.permanent_domain }}';
    var container  = document.getElementById('wp-feed-posts-' + blockId);

    if (!container) return;

    function formatDate(raw) {
      try {
        return new Intl.DateTimeFormat(undefined, { year: 'numeric', month: 'short', day: 'numeric' }).format(new Date(raw));
      } catch(e) { return raw || ''; }
    }

    function stripTags(html) {
      var tmp = document.createElement('div');
      tmp.innerHTML = html || '';
      return tmp.textContent || tmp.innerText || '';
    }

    fetch('https://simple-wordpress-post-feed-production.up.railway.app/api/posts?shop=' + shopDomain)
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (!data || !data.posts || !data.posts.length) {
          container.innerHTML = '<p class="wp-feed-empty">No posts available.</p>';
          return;
        }
        container.innerHTML = data.posts.map(function(post) {
          var excerpt = stripTags(post.excerpt || '');
          var date    = formatDate(post.date);
          return '<article class="wp-feed-post">'
            + '<a class="wp-feed-post__link" href="' + post.url + '" target="_blank" rel="noopener">'
            +   '<h3 class="wp-feed-post__title">' + post.title + '</h3>'
            + '</a>'
            + (date ? '<time class="wp-feed-post__date">' + date + '</time>' : '')
            + (excerpt ? '<p class="wp-feed-post__excerpt">' + excerpt + '</p>' : '')
            + '</article>';
        }).join('');
      })
      .catch(function(err) {
        console.error('Error loading WordPress feed:', err);
        container.innerHTML = '<p class="wp-feed-empty">Unable to load posts at this time.</p>';
      });
  })();
</script>

<style>
  /* ── Outer container ── */
  .wordpress-feed-block {
    padding: 2rem 0;
  }

  .wp-feed-container {
    max-width: 760px;
  }

  /* ── Section heading ── */
  .wp-feed-title {
    font-size: 1.25rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    margin: 0 0 1.5rem;
    padding-bottom: 0.75rem;
    border-bottom: 2px solid currentColor;
    opacity: 0.9;
  }

  /* ── Individual post ── */
  .wp-feed-post {
    padding: 1.25rem 0;
    border-bottom: 1px solid rgba(0, 0, 0, 0.1);
  }

  .wp-feed-post:first-child {
    padding-top: 0;
  }

  .wp-feed-post:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  /* ── Post link ── */
  .wp-feed-post__link {
    text-decoration: none;
    color: inherit;
    display: inline-block;
  }

  .wp-feed-post__link:hover .wp-feed-post__title {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  /* ── Post title ── */
  .wp-feed-post__title {
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.4;
    margin: 0 0 0.35rem;
  }

  /* ── Date ── */
  .wp-feed-post__date {
    display: block;
    font-size: 0.75rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    opacity: 0.55;
    margin-bottom: 0.5rem;
  }

  /* ── Excerpt ── */
  .wp-feed-post__excerpt {
    font-size: 0.875rem;
    line-height: 1.6;
    margin: 0;
    opacity: 0.75;
    /* Clamp to 3 lines */
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ── States ── */
  .wp-feed-loading,
  .wp-feed-empty {
    font-size: 0.875rem;
    opacity: 0.55;
    margin: 0;
    padding: 0.5rem 0;
  }

  /* ── Mobile ── */
  @media (max-width: 749px) {
    .wordpress-feed-block {
      padding: 1.5rem 0;
    }

    .wp-feed-title {
      font-size: 1.1rem;
      margin-bottom: 1.25rem;
    }

    .wp-feed-post {
      padding: 1rem 0;
    }

    .wp-feed-post__title {
      font-size: 0.9375rem;
    }
  }
</style>

{% schema %}
{
  "name": "WordPress Post Feed",
  "target": "body",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Feed Title",
      "default": "Latest Posts"
    },
    {
      "type": "checkbox",
      "id": "show_title",
      "label": "Show Title",
      "default": true
    },
    {
      "type": "range",
      "id": "post_count",
      "label": "Number of Posts",
      "min": 1,
      "max": 20,
      "default": 5,
      "step": 1
    }
  ]
}
{% endschema %}
