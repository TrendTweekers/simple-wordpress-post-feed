{% comment %}
  WordPress Post Feed Block
  This block displays WordPress blog posts on Shopify store pages
{% endcomment %}

<div class="wordpress-feed-block" data-shop="{{ shop.permanent_domain }}" data-app-id="{{ app.id }}">
  <div class="wp-feed-container">
    {% if block.settings.show_title %}
      <h2 class="wp-feed-title">{{ block.settings.title | default: "Latest Posts" }}</h2>
    {% endif %}

    <div class="wp-feed-posts" id="wp-feed-posts-{{ block.id }}" data-layout="{{ block.settings.layout | default: 'list' }}">
      <p class="wp-feed-loading">Loading posts&hellip;</p>
    </div>
  </div>
</div>

<script>
  (function() {
    var blockId   = '{{ block.id }}';
    var shopDomain = '{{ shop.permanent_domain }}';
    var container  = document.getElementById('wp-feed-posts-' + blockId);

    if (!container) return;

    function formatDate(raw) {
      try {
        return new Intl.DateTimeFormat(undefined, { year: 'numeric', month: 'short', day: 'numeric' }).format(new Date(raw));
      } catch(e) { return raw || ''; }
    }

    function stripTags(html) {
      var tmp = document.createElement('div');
      tmp.innerHTML = html || '';
      return tmp.textContent || tmp.innerText || '';
    }

    var postCount = {{ block.settings.post_count | default: 5 }};
    var showImage = {{ block.settings.show_image | default: true }};
    fetch('https://simple-wordpress-post-feed-production.up.railway.app/api/posts?shop=' + shopDomain + '&count=' + postCount)
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (!data || !data.posts || !data.posts.length) {
          container.innerHTML = '<p class="wp-feed-empty">No posts available.</p>';
          return;
        }
        container.innerHTML = data.posts.map(function(post) {
          var excerpt = stripTags(post.excerpt || '');
          var date    = formatDate(post.date);
          var imageHtml = (showImage && post.image)
            ? '<img class="wp-feed-post__image" src="' + post.image + '" alt="" loading="lazy" decoding="async">'
            : '';
          return '<article class="wp-feed-post">'
            + imageHtml
            + '<a class="wp-feed-post__link" href="' + post.url + '" target="_blank" rel="noopener">'
            +   '<h3 class="wp-feed-post__title">' + post.title + '</h3>'
            + '</a>'
            + (date ? '<time class="wp-feed-post__date">' + date + '</time>' : '')
            + (excerpt ? '<p class="wp-feed-post__excerpt">' + excerpt + '</p>' : '')
            + '</article>';
        }).join('');
      })
      .catch(function(err) {
        console.error('Error loading WordPress feed:', err);
        container.innerHTML = '<p class="wp-feed-empty">Unable to load posts at this time.</p>';
      });
  })();
</script>

<style>
  .wordpress-feed-block {
    padding: 4rem 0;
  }

  .wp-feed-container {
    max-width: 72rem;
    margin-left: auto;
    margin-right: auto;
    padding-left: 1.5rem;
    padding-right: 1.5rem;
  }

  .wp-feed-title {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin: 0 0 2.5rem;
    opacity: 0.55;
  }

  .wp-feed-posts {
    display: flex;
    flex-direction: column;
  }

  .wp-feed-post {
    padding: 1.75rem 0;
    border-bottom: 1px solid rgba(0, 0, 0, 0.1);
  }

  .wp-feed-post:first-child {
    padding-top: 0;
  }

  .wp-feed-post:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .wp-feed-post__link {
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .wp-feed-post__title {
    font-size: 1.125rem;
    font-weight: 600;
    line-height: 1.35;
    margin: 0 0 0.5rem;
    transition: opacity 0.2s ease;
  }

  .wp-feed-post__link:hover .wp-feed-post__title {
    opacity: 0.6;
  }

  .wp-feed-post__date {
    display: block;
    font-size: 0.75rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    opacity: 0.4;
    margin-bottom: 0.625rem;
  }

  .wp-feed-post__excerpt {
    font-size: 0.9375rem;
    line-height: 1.7;
    margin: 0;
    opacity: 0.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .wp-feed-loading,
  .wp-feed-empty {
    font-size: 0.875rem;
    opacity: 0.4;
    margin: 0;
    padding: 1rem 0;
    text-align: center;
  }

  /* ── Compact ── */
  .wp-feed-posts[data-layout="compact"] .wp-feed-post {
    padding: 0.875rem 0;
  }
  .wp-feed-posts[data-layout="compact"] .wp-feed-post__title {
    font-size: 0.9375rem;
    font-weight: 500;
    margin-bottom: 0;
  }
  .wp-feed-posts[data-layout="compact"] .wp-feed-post__date {
    font-size: 0.6875rem;
    margin-bottom: 0.25rem;
  }
  .wp-feed-posts[data-layout="compact"] .wp-feed-post__excerpt {
    display: none;
  }

  /* ── Cards ── */
  .wp-feed-posts[data-layout="cards"] {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1.5rem;
  }
  .wp-feed-posts[data-layout="cards"] .wp-feed-post {
    padding: 1.5rem;
    border: 1px solid rgba(0, 0, 0, 0.09);
    border-radius: 0.75rem;
    transition: box-shadow 0.2s ease, border-color 0.2s ease;
  }
  .wp-feed-posts[data-layout="cards"] .wp-feed-post:hover {
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
    border-color: rgba(0, 0, 0, 0.15);
  }
  .wp-feed-posts[data-layout="cards"] .wp-feed-post:first-child {
    padding-top: 1.5rem;
  }
  .wp-feed-posts[data-layout="cards"] .wp-feed-post:last-child {
    border-bottom: 1px solid rgba(0, 0, 0, 0.09);
    padding-bottom: 1.5rem;
  }
  .wp-feed-posts[data-layout="cards"] .wp-feed-post__excerpt {
    -webkit-line-clamp: 3;
  }

  /* ── Mobile ── */
  @media (max-width: 749px) {
    .wordpress-feed-block {
      padding: 2.5rem 0;
    }

    .wp-feed-container {
      padding-left: 1.25rem;
      padding-right: 1.25rem;
    }

    .wp-feed-title {
      margin-bottom: 2rem;
    }

    .wp-feed-post {
      padding: 1.25rem 0;
    }

    .wp-feed-post__title {
      font-size: 1rem;
    }

    .wp-feed-post__excerpt {
      font-size: 0.875rem;
      line-height: 1.6;
    }

    .wp-feed-posts[data-layout="cards"] {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .wp-feed-posts[data-layout="compact"] .wp-feed-post {
      padding: 0.75rem 0;
    }
  }

  /* ── Featured image ── */
  .wp-feed-post__image {
    display: block;
    width: 100%;
    aspect-ratio: 2 / 1;
    object-fit: cover;
    border-radius: 0.5rem;
    margin-bottom: 1.25rem;
  }

  .wp-feed-posts[data-layout="cards"] .wp-feed-post__image {
    aspect-ratio: 16 / 9;
    border-radius: 0.625rem 0.625rem 0 0;
    margin: -1.5rem -1.5rem 1.25rem;
    width: calc(100% + 3rem);
  }

  .wp-feed-posts[data-layout="compact"] .wp-feed-post__image {
    display: none;
  }
</style>

{% schema %}
{
  "name": "WordPress Post Feed",
  "target": "body",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_image",
      "label": "Show Featured Image",
      "default": true
    },
    {
      "type": "text",
      "id": "title",
      "label": "Feed Title",
      "default": "Latest Posts"
    },
    {
      "type": "checkbox",
      "id": "show_title",
      "label": "Show Title",
      "default": true
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "default": "list",
      "options": [
        { "value": "list",    "label": "List"    },
        { "value": "compact", "label": "Compact" },
        { "value": "cards",   "label": "Cards"   }
      ]
    },
    {
      "type": "range",
      "id": "post_count",
      "label": "Number of Posts",
      "min": 1,
      "max": 20,
      "default": 5,
      "step": 1
    }
  ]
}
{% endschema %}
