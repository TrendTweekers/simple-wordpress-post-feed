<style>
   /*Start of common*/
   #swpf-feed {
    border-bottom: 1px solid {{ section.settings.swpf_border_color}};
    border-top: 1px solid {{ section.settings.swpf_border_color}};
    background: {{ section.settings.swpf_background_color }};
    padding:{{ section.settings.swpf_padding_y}}px 0;
  }

       .swpf-skeleton {
      background-color: #dfe3e8;
      animation: swpf-SkeletonAnimation 0.8s linear infinite alternate;
    }

    .swpf_container {
    max-width: {{ section.settings.swpf_container_width }};
    padding-right: 15px;
    padding-left: 15px;
    margin-right: auto;
    margin-left: auto;
  }

        .swpf_container_full {
      width: 100%;  
      padding-right: 15px;
      padding-left: 15px;
      margin-right: auto;
      margin-left: auto;
    }

         .swpf_section-heading {
      padding: 10px 15px;
    }

        @keyframes swpf-SkeletonAnimation {
      0% {
        opacity: 0.45;
      }

          100% {
        opacity: 0.9;
      }
    }

            .swpf_box_title {
      font-weight: {{ section.settings.swpf_font_weight}};
      font-size: {{ section.settings.swpf_font_size}}px;
      color: {{ section.settings.swpf_front_color}};
      padding-bottom: 10px; 
    }



              /* End of common
     */

        /*Only for normal*/
    /*///////////////////////////////////////////////////////////////////////////////*/
    .swpf-container {
    width: 100%;
    display: flex;
    flex-wrap: wrap;
  }
    .swpf-box {
    position: relative;
    background: #eaeaea;
    border: 1px solid rgba(109, 109, 109, 0.2);
    flex: 1 0 calc(25% - 10px);
    line-height: 1.1;
    margin:  {{ section.settings.swpf_margin }}px;
  }

        .swpf-box:after {
    content: "";
    display: block;
    padding-bottom: 100%;
  }

    .swpf-box img {
    position: absolute;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 1;
  }


      .swpf-content {
    position: absolute;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    top: 0;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 2;
    background: {{ section.settings.swpf_overlay | color_modify: 'alpha', section.settings.swpf_overlay_opacity }};
    padding: 5px;
    color: #fff;
  }
    .text-center {
    text-align: center;
  }

        @media screen and (max-width: 750px) {
    .swpf-box {
    flex: 1 0 calc(50% - 10px);
    }
    .swpf_box_text {
      font-size: {{ section.settings.swpf_font_size_sm}}px;
      padding-bottom: 5px;
    }

      .swpf_container {
      padding-right: 10px;
      padding-left: 10px;
      }
      .swpf_container_full {
        padding-right: 10px;
        padding-left: 10px;
      }

      }

         /* END OF Only for normal*/

      /*   Only for option with excerpt */
        .swpf-container-ex {
    display: flex;
    position: relative;
    flex-wrap: wrap;
    justify-content: center;
     max-width: {{ section.settings.swpf_container_width }};
       padding-right: 15px;
      padding-left: 15px;
      margin-right: auto;
      margin-left: auto; 
      padding:{{ section.settings.swpf_padding_y}}px 0;
    }



                .swpf-box-ex {
    box-shadow: 0 0 5px 0 #00000014;
      margin:  {{ section.settings.swpf_margin }}px;
      display:flex;
      flex-direction:column;
      justify-content:space-between;
      background: {{ section.settings.swpf_excerpt_background_color }};
       position: relative;
          border: 1px solid {{ section.settings.swpf_border_color}};
      padding:{{ section.settings.swpf_padding_y}}px 0;
  }




              .swpf-link-ex {
      display: {% if section.settings.swpf_excerpt_btn == true %}
      block
    {% else %}
      none
      {% endif %};
      text-align: center;
      border: black 1px solid;
      color: {{ section.settings.swpf_front_color}};
      border-radius:5px;
      transition: 0.3s;
  }
      .swpf-link-ex:hover {
        background-color: {{section.settings.swpf_excerpt_btn_color}};
  }


          .swpf-box-ex img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      z-index: 1;
    } 


             .swpf-content-ex {
      justify-content: center;
      top: 0;
      bottom: 0;
      left: 0;
      right: 0;
      z-index: 2;
      padding: 5px;
      color:{{ section.settings.swpf_font_color }};
      text-align: center;
    } 

        .swpf-content-ex p {
      text-align: {{ section.settings.swpf_excerpt_text_align }};
      color: {{ section.settings.swpf_front_color}};
    }




                    @media screen and (max-width: 750px) {
      .swpf-box-ex {
      flex: 1 0 calc(50% - 10px);
      }
      .swpf_box_title-ex {
        font-size: {{ section.settings.swpf_font_size_sm}}px;
        padding-bottom: 5px;
      }

          .swpf_container {
        padding-right: 10px;
        padding-left: 10px;
        }
        .swpf_container_full {
          padding-right: 10px;
          padding-left: 10px;
        }

          }
    .swpf-box-ex {
    width: 100%;
    margin-bottom: 20px;
    padding: 0;
  }
  @media (min-width: 600px) {
    .swpf-box-ex {
      width: 30%;
      padding: 10px;
    }
  }
  @media (min-width: 1200px) {
    .swpf-box-ex {
      width: 20%;
      padding: 10px;
    }
  }

        .swpf-image-ex{
      height: {{ section.settings.swpf_excerpt_image_height}}px
    }
  /* End of only with excerpt*/
</style>

  {% for block in section.blocks %}
  {% if block.type == 'html' %}
  <style>
  {{block.settings.swpf_css}}
  </style>
  {% endif %} {% endfor %}

<div class="section feed" id="swpf-feed" data-wp="{{ section.settings.swpf_wp_hosted }}" data-generate-images="{{section.settings.swpf_generate_images}}" 
  data-url="{{ section.settings.swpf_url }}"data-posts="{{ section.settings.number_posts }}" data-author="" data-category="{{ section.settings.swpf_category }}"
  data-tags="{{ section.settings.swpf_tags }}" data-slug="{{ section.settings.swpf_slug }}" data-tags_exclude="{{ section.settings.swpf_tags_exclude }}"
  data-target="{{section.settings.swpf_target }}"
  data-show_excerpt="{{section.settings.swpf_excerpt }}"
  data-excerpt_length="{{section.settings.swpf_excerpt_length }}"
  data-excerpt-clickable="{{section.settings.swpf_excerpt_click}}"
  data-excerpt-btn-text="{{section.settings.swpf_excerpt_btn_text}}"
     >


  {% for block in section.blocks %}

  {% if block.type == 'html' %}
  {{block.settings.swpf_html}}
  {% endif %}


  {% if block.type == 'text' %}
  <header class="swpf_section-heading  text-center block-heading">
    <div class="swpf-head">
      <h2 class="swpf-title text-center">
        {{block.settings.swpf_title | escape}}
      </h2>
    </div>
    <div class="block-swpf_subtitle">
      <p class="swpf_subtitle text-center">
        {{block.settings.swpf_subtitle | escape}}
      </p>
    </div>
  </header>
  {% endif %}
  {% endfor %}

  <div class="{% if section.settings.swpf_checkbox %}swpf_container_full{% else %}swpf_container{% endif %}">
    <div id="wpsContent"></div>
  </div>


  {% schema %}

  {
    "name": "Wordpress Post Feed",
    "class": "index-section wp-feed",
    "target": "section",
    "settings": [
      {
        "type": "text",
        "id": "swpf_url",
        "label": "Wordpress url",
        "default": "https://stackedboost.com",
        "placeholder": "url to your wordpress"
      },
      {
        "type": "checkbox",
        "id": "swpf_wp_hosted",
        "default": false,
        "label": "Hosted on wordpress.com"
      },
      {
        "type": "range",
        "id": "number_posts",
        "min": 1,
        "max": 100,
        "step": 1,
        "label": "Number of posts to display",
        "default": 3
      },
      {
        "type": "text",
        "id": "swpf_category",
        "label": "Limit to category",
        "placeholder": "Category ID (number)"
      },
      {
        "type": "text",
        "id": "swpf_tags",
        "label": "Limit to tags",
        "info": "e.g.:11,21,22",
        "placeholder": "Tag ID (number)"
      },
      {
        "type": "text",
        "id": "swpf_slug",
        "label": "Limit to slugs",
        "info": "e.g.:cars,red",
        "placeholder": "Slug"
      },
      {
        "type": "text",
        "id": "swpf_tags_exclude",
        "label": "Tags exclude",
        "info": "e.g.:12,22,23",
        "placeholder": "Excluded Tag ID (number)"
      },
      {
        "type": "text",
        "id": "swpf_container_width",
        "label": "Container Max width",
        "placeholder": "960px",
        "default": "1090px"
      },
      {
        "type": "checkbox",
        "id": "swpf_checkbox",
        "label": "Full width",
        "default": false
      },
      {
        "type": "checkbox",
        "id": "swpf_target",
        "label": "Open link on current page",
        "default": false
      },
      {
        "type": "range",
        "id": "swpf_padding_y",
        "min": 0,
        "max": 200,
        "step": 2,
        "label": "Container Padding Y Axis",
        "unit": "px",
        "default": 50
      },
      {
        "type": "color",
        "id": "swpf_border_color",
        "label": "Border color",
        "default": "#ececec"
      },
      {
        "type": "range",
        "id": "swpf_margin",
        "min": 0,
        "max": 20,
        "step": 1,
        "label": "Post spacing",
        "default": 5
      },
      {
        "type": "range",
        "id": "swpf_font_size",
        "min": 5,
        "max": 70,
        "step": 1,
        "unit": "px",
        "label": "Font size desktop",
        "default": 16
      },
      {
        "type": "range",
        "id": "swpf_font_size_sm",
        "min": 5,
        "max": 70,
        "step": 1,
        "unit": "px",
        "label": "Font size mobile",
        "default": 12
      },
      {
        "type": "range",
        "id": "swpf_font_weight",
        "min": 100,
        "max": 900,
        "step": 100,
        "label": "Font weight",
        "default": 600
      },
      {
        "type": "color",
        "id": "swpf_background_color",
        "label": "Background color",
        "default": "#ffffff"
      },
      {
        "type": "color",
        "id": "swpf_front_color",
        "label": "Font color",
        "default": "#ffffff"
      },
      {
        "type": "color",
        "id": "swpf_overlay",
        "label": "Overlay color",
        "default": "#000000"
      },
      {
        "type": "range",
        "id": "swpf_overlay_opacity",
        "min": 0,
        "max": 1,
        "step": 0.1,
        "label": "Overlay opacity",
        "default": 0.2
      },
      {
        "type": "checkbox",
        "id": "swpf_excerpt",
        "label": "Show excerpt",
        "default": false,
        "info": "Beta! If any issues please contact us  [StackedBoost-Support](mailto:support@stackedboosthelp.zendesk.com)"
      },
      {
        "type": "select",
        "id": "swpf_excerpt_text_align",
        "label": "Text align",
        "options": [
          {
            "value": "left",
            "label": "left"
          },
          {
            "value": "right",
            "label": "right"
          },
          {
            "value": "center",
            "label": "center"
          },
          {
            "value": "justify",
            "label": "justify"
          }
        ],
        "default": "center"
      },
      {
        "type": "range",
        "id": "swpf_excerpt_length",
        "min": 50,
        "max": 200,
        "step": 5,
        "label": "Length of excerpt",
        "default": 50
      },
      {
        "type": "range",
        "id": "swpf_excerpt_image_height",
        "min": 150,
        "max": 350,
        "step": 10,
        "label": "Height of excerpt image",
        "default": 250
      },
      {
        "type": "color",
        "id": "swpf_excerpt_background_color",
        "label": "Box background",
        "default": "#ffffff"
      }
    ]
  }



        {% endschema %}