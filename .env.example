# Shopify App credentials
SHOPIFY_API_KEY=your_shopify_api_key
SHOPIFY_API_SECRET=your_shopify_api_secret_key
SHOP=your-dev-store.myshopify.com
SCOPES=write_themes,read_themes,read_script_tags,write_script_tags
HOST=https://your-tunnel-or-railway-url.com
THEME_APP_EXTENSION_UUID=your_theme_app_extension_uuid

# Telegram notifications (optional — alerts are silently skipped if unset)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
