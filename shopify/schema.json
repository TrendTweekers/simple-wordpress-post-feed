{
  "name": "Wordpress",
  "class": "index-section wp-feed",
  "tag": "section",
  "presets": [
    {
      "name": "Wordpress Feed",

      "category": "Text"
    }
  ],
  "settings": [
    {
      "type": "text",
      "id": "wp_url",
      "label": "Wordpress url",
      "default": "http://academy.restlessmama.com"
    },

    {
      "type": "text",
      "id": "title",
      "label": "Heading Wordpress Feed",
      "default": "i am Title"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle Wordpress Feed",
      "default": "i am Subtile"
    },
    {
      "type": "range",
      "id": "number_posts",
      "min": 1,
      "max": 100,
      "step": 1,
      "label": "Number of posts to display",
      "default": 4
    },
    {
      "type": "select",
      "id": "design",
      "label": "Design",
      "options": [
        {
          "value": "1",
          "label": "Design 1"
        },
        {
          "value": "2",
          "label": "Design 2"
        },
        {
          "value": "3",
          "label": "Design 3"
        }
      ]
    }
  ]
}
